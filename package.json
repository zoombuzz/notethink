{
  "name": "notethink",
  "displayName": "%displayName%",
  "author": "NoteThink",
  "publisher": "NoteThink",
  "description": "%description%",
  "version": "0.3.16",
  "license": "Apache-2.0",
  "icon": "media/icon.png",
  "homepage": "https://www.notethink.com",
  "bugs": {
    "url": "https://github.com/zoombuzz/notethink/issues"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zoombuzz/notethink.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "keywords": [
    "multi-root ready"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCustomEditor:notethink.viewer",
    "onWebviewPanel:notethink",
    "onStartupFinished"
  ],
  "l10n": "./l10n",
  "browser": "./client/extension/dist/extension",
  "contributes": {
    "customEditors": [
      {
        "viewType": "notethink.viewer",
        "displayName": "%editor.displayName%",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "notethink.openViewer",
        "title": "%command.openViewer%"
      },
      {
        "command": "notethink.setViewAuto",
        "title": "%command.setViewAuto%",
        "icon": "$(eye)"
      },
      {
        "command": "notethink.setViewDocument",
        "title": "%command.setViewDocument%",
        "icon": "$(file-text)"
      },
      {
        "command": "notethink.setViewKanban",
        "title": "%command.setViewKanban%",
        "icon": "$(project)"
      },
      {
        "command": "notethink.toggleLineNumbers",
        "title": "%command.toggleLineNumbers%"
      },
      {
        "command": "notethink.toggleContextBars",
        "title": "%command.toggleContextBars%"
      },
      {
        "command": "notethink.navigateUp",
        "title": "%command.navigateUp%"
      },
      {
        "command": "notethink.navigateDown",
        "title": "%command.navigateDown%"
      },
      {
        "command": "notethink.drillIn",
        "title": "%command.drillIn%"
      },
      {
        "command": "notethink.drillOut",
        "title": "%command.drillOut%"
      },
      {
        "command": "notethink.clearFocus",
        "title": "%command.clearFocus%"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "notethink.setViewAuto",
          "when": "activeCustomEditorId == 'notethink.viewer'",
          "group": "navigation@1"
        },
        {
          "command": "notethink.setViewDocument",
          "when": "activeCustomEditorId == 'notethink.viewer'",
          "group": "navigation@2"
        },
        {
          "command": "notethink.setViewKanban",
          "when": "activeCustomEditorId == 'notethink.viewer'",
          "group": "navigation@3"
        },
        {
          "command": "notethink.toggleLineNumbers",
          "when": "activeCustomEditorId == 'notethink.viewer'",
          "group": "1_settings"
        },
        {
          "command": "notethink.toggleContextBars",
          "when": "activeCustomEditorId == 'notethink.viewer'",
          "group": "1_settings"
        }
      ]
    },
    "keybindings": [
      {
        "command": "notethink.clearFocus",
        "key": "escape",
        "when": "activeCustomEditorId == 'notethink.viewer'"
      },
      {
        "command": "notethink.navigateUp",
        "key": "up",
        "when": "activeCustomEditorId == 'notethink.viewer'"
      },
      {
        "command": "notethink.navigateDown",
        "key": "down",
        "when": "activeCustomEditorId == 'notethink.viewer'"
      },
      {
        "command": "notethink.drillIn",
        "key": "enter",
        "when": "activeCustomEditorId == 'notethink.viewer'"
      },
      {
        "command": "notethink.drillOut",
        "key": "backspace",
        "when": "activeCustomEditorId == 'notethink.viewer'"
      }
    ],
    "configuration": [
      {
        "order": 22,
        "id": "notethink-extension",
        "title": "%config.title%",
        "properties": {
          "notethink-extension.trace.server": {
            "type": "string",
            "scope": "window",
            "enum": [
              "off",
              "messages",
              "verbose"
            ],
            "default": "verbose",
            "description": "%config.trace.description%"
          },
          "notethink.settings.view.type": {
            "type": "string",
            "scope": "resource",
            "enum": ["auto", "document", "kanban"],
            "default": "auto",
            "description": "%config.settings.view.type.description%"
          },
          "notethink.settings.view.generic.showLineNumbers": {
            "type": "boolean",
            "scope": "resource",
            "default": false,
            "description": "%config.settings.view.generic.showLineNumbers.description%"
          },
          "notethink.settings.view.generic.watchUnopenedFilesInViewer": {
            "type": "boolean",
            "scope": "window",
            "default": true,
            "description": "%config.settings.view.generic.watchUnopenedFilesInViewer.description%"
          },
          "notethink.settings.view.generic.showContextBars": {
            "type": "boolean",
            "scope": "resource",
            "default": true,
            "description": "%config.settings.view.generic.showContextBars.description%"
          },
          "notethink.settings.view.specific.kanban.columnOrder": {
            "type": "array",
            "scope": "resource",
            "items": { "type": "string" },
            "default": ["untagged", "doing", "code-review", "testing", "done"],
            "description": "%config.settings.view.specific.kanban.columnOrder.description%"
          },
          "notethink.settings.view.specific.kanban.animateTransitions": {
            "type": "boolean",
            "scope": "window",
            "default": true,
            "description": "%config.settings.view.specific.kanban.animateTransitions.description%"
          },
          "notethink.settings.files.includeFilter": {
            "type": "string",
            "scope": "resource",
            "default": "**/*.md",
            "description": "%config.settings.files.includeFilter.description%"
          },
          "notethink.settings.files.excludeFilter": {
            "type": "string",
            "scope": "resource",
            "default": "**/{node_modules,.git,.svn,.hg,.terraform,.claude,dist,build,out,.next,.cache,coverage}/**",
            "description": "%config.settings.files.excludeFilter.description%"
          },
          "notethink.settings.files.maxNotesPerFile": {
            "type": "integer",
            "scope": "resource",
            "minimum": 1,
            "default": 10,
            "description": "%config.settings.files.maxNotesPerFile.description%"
          }
        }
      }
    ]
  },
  "scripts": {
    "prepublishOnly": "pnpm run package",
    "bump-version": "npm version patch --no-git-tag-version",
    "test-jest": "bash scripts/test-jest.sh",
    "test-playwright": "pnpm run build && playwright test",
    "lint": "eslint . && tsc --noEmit -p client/extension && tsc --noEmit -p client/webview && tsc --noEmit -p client/webview/src/notethink-views",
    "check": "pnpm run lint && pnpm run build-and-rollup && pnpm run test-jest",
    "build-and-rollup": "pnpm run build && cd client/webview/src/notethink-views && pnpm run rollup",
    "l10n-export": "vscode-l10n-dev export --outDir ./l10n ./client/extension/src ./client/webview/src",
    "check-updates": "ncu -u",
    "vscode:prepublish": "pnpm run package",
    "build": "SELFINSPECT_ENV=dev webpack",
    "watch": "SELFINSPECT_ENV=dev webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "postinstall": "cd client/extension && pnpm install && cd ../../ && cd client/webview && pnpm install && cd ../.. && cd client/webview/src/notethink-views && pnpm install && cd ../../../..",
    "package:vsix": "vsce package --no-dependencies",
    "publish:marketplace": ": \"${TF_VAR_notethink_vsce_alex_publishonly_pat:?missing - provisioned via puppet-managed ~/.bash_envvars}\" && VSCE_PAT=\"$TF_VAR_notethink_vsce_alex_publishonly_pat\" vsce publish --no-dependencies",
    "test-playwright-with-ui": "pnpm run build && playwright test --ui",
    "chrome": "pnpm run build && vscode-test-web --browserType=chromium --extensionDevelopmentPath=. ./docstech"
  },
  "COMMENT-dependencies-are-webpack-browser-polyfills-for-extension": "",
  "dependencies": {
    "browserify-zlib": "^0.2.0",
    "buffer": "^6.0.3",
    "events": "^3.3.0",
    "https-browserify": "^1.0.0",
    "memfs": "^4.57.7",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "url": "^0.11.4",
    "util": "^0.12.5"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "^1.61.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/debug": "^4.1.13",
    "@types/mocha": "^10.0.10",
    "@types/vscode": "^1.120.0",
    "@types/webpack-env": "^1.18.8",
    "@vscode/l10n-dev": "^0.0.35",
    "@vscode/test-web": "^0.0.80",
    "@vscode/vsce": "^3.9.2",
    "assert": "^2.1.0",
    "copy-webpack-plugin": "14.0.0",
    "css-loader": "^7.1.4",
    "debug": "^4.4.3",
    "eslint": "9.39.4",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-frontmatter": "^2.0.1",
    "mdast-util-gfm": "^3.1.0",
    "micromark-extension-frontmatter": "^2.0.0",
    "micromark-extension-gfm": "^3.0.0",
    "mocha": "^11.7.6",
    "npm-check-updates": "^22.2.3",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  }
}
