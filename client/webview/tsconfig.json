{
    "compilerOptions": {
        "target": "ES2023",
        "module": "esnext",
        "moduleResolution": "bundler",
        "lib": ["dom", "dom.iterable", "ES2023"],
        "allowJs": true,
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "resolveJsonModule": true,
        "noEmit": false,
        "jsx": "react-jsx",
        "forceConsistentCasingInFileNames": true,
        "noFallthroughCasesInSwitch": true
    },
    "include": ["src"],
    "exclude": ["node_modules", ".vscode-test-web", "src/setupEnv.js", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
