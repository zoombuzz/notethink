{
    "compilerOptions": {
        "target": "ES2023",
        "module": "esnext",
        "moduleResolution": "bundler",
        "lib": ["WebWorker", "ES2023"],
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "resolveJsonModule": true,
        "noEmit": false,
        "rootDir": "src",
        "sourceMap": true
    },
    "include": ["src"],
    "exclude": ["node_modules", ".vscode-test-web"]
}
