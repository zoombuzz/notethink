{
  "name": "notethink",
  "displayName": "NoteThink",
  "publisher": "ZoomBuzz",
  "description": "Notes in markdown, visualised as anything",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "browser": "./client/extension/dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "zoombuzz.notethink",
        "displayName": "NoteThink",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "notethink.openview",
        "title": "NoteThink: Open View"
      }
    ]
  },
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "webpack",
		"watch": "webpack --watch",
		"package": "webpack --mode production --devtool hidden-source-map",
		"lint": "eslint",
		"postinstall": "cd client/extension && npm install && cd ../../ && cd client/webview && npm install && cd ../..",
		"chrome": "npm run compile && vscode-test-web --browserType=chromium --extensionDevelopmentPath=. ./docstech/testdata"
	},
  "COMMENT-dependencies-are-webpack-browser-polyfills-for-extension": "",
  "dependencies": {
		"os-browserify": "^0.3.0",
		"https-browserify": "^1.0.0",
		"path-browserify": "^1.0.1",
		"stream-http": "^3.2.0",
		"stream-browserify": "^3.0.0",
		"buffer": "^6.0.3",
		"browserify-zlib": "^0.2.0",
		"memfs": "^4.17.1",
		"url": "^0.11.0",
    "util": "^0.12.5"
  },
	"devDependencies": {
		"@types/webpack-env": "^1.18.8",
		"@types/vscode": "^1.73.0",
		"@types/mocha": "^10.0.10",
		"@eslint/js": "^9.13.0",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@vscode/test-web": "^0.0.51",
		"eslint": "^9.13.0",
		"path-browserify": "^1.0.1",
    "debug": "^4.4.0",
		"mocha": "^11.1.0",
		"assert": "^2.1.0",
    "process":"^0.11.10",
		"ts-loader": "^9.5.1",
		"typescript": "^5.8.2",
		"typescript-eslint": "^8.26.0",
		"webpack": "^5.90.1",
		"webpack-cli": "^5.1.4",
    "copy-webpack-plugin": "13.0.0"
  }
}
