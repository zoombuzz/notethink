# Editor config (root only)
.idea
.vscode-test-web

# Github pages/MM
docs/_site
.sass-cache
.jekyll-metadata
Gemfile.lock

# Terraform local files
**/.terraform/*
**/.terraform.*
*.tfstate
*.tfstate.*
*.tfvars
nohup.out

# Node.js dev
**/node_modules
/.pnp
.pnp.js
.env
.env*.local
.env*.local-docker
**/.env.development.local

# Python dev
*_venv/
*__pycache__*

# typescript
*.tsbuildinfo

# build outputs
**/dist/

# stale in-place tsc output (source of truth is the .ts; webpack bundles from .ts)
client/extension/src/**/*.js
client/extension/src/**/*.js.map

# service workers
**/public/sw.js
**/public/sw.js.map
**/public/workbox-*

# ignore dynamically generated secrets files
**/dynamic-secrets.*.yaml

# ignore spurious logs
app/debug.log
**/newrelic_agent.log
**/notethink-extension.log

# design logo renders (regenerate from docstech/design/logos/*.svg)
docstech/design/logos/render/

# misc
.DS_Store
*.pem
*.vsix

# jest/swc/playwright
**/.swc
**/playwright/tmp
**/test-results
.playwright-mcp/

# Exclude local Claude Code runtime state, but version skills
.claude/*
!.claude/skills/
